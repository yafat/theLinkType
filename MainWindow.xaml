<Window x:Class="theLinkType.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="theLinkType"
        Width="820"
        Height="560"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
               VerticalAlignment="Center"
               FontSize="22"
               FontWeight="Bold"
               Text="theLinkType"/>

            <CheckBox x:Name="TranslationToggle"
              Grid.Column="1"
              Margin="0,0,12,0"
              VerticalAlignment="Center"
              Checked="TranslationToggle_Checked"
              Unchecked="TranslationToggle_Unchecked"
              Content="翻譯"/>

            <ComboBox x:Name="LanguageComboBox"
              Grid.Column="2"
              Width="140"
              Height="30"
              VerticalAlignment="Center"
              Visibility="Collapsed"
              SelectedIndex="0">
                <ComboBoxItem Content="English"/>
                <ComboBoxItem Content="Japanese"/>
                <ComboBoxItem Content="Korean"/>
            </ComboBox>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,16,0,16"
                BorderBrush="#CCC"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8">
            <RichTextBox x:Name="OutputBox"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="16"
                         AcceptsReturn="True" />
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="StartButton"
                    Width="100"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="StartButton_Click">START</Button>
            <Button x:Name="StopButton"
                    Width="100"
                    Height="34"
                    Click="StopButton_Click">STOP</Button>
        </StackPanel>
    </Grid>
</Window>